# Copy to .env and fill in. Application code uses no defaults — every variable below must be set.
# Use real API keys and expand SYMBOLS / CRYPTO_SYMBOLS to your universe.

STOCK_DATA_API_KEY=your_twelve_data_api_key
# Optional: second / third Twelve Data keys — used in order if earlier keys hit rate/credit errors
STOCK_DATA_API_KEY_SECONDARY=
STOCK_DATA_API_KEY_TERTIARY=

OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
XAI_API_KEY=your_xai_api_key

OPENAI_MODEL=gpt-4.1
GEMINI_MODEL=gemini-3-flash-preview
# Claude: use a current API id (see https://platform.claude.com/docs/en/about-claude/models/overview ).
# Examples: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5
# Do not use claude-3-5-sonnet-latest / *-latest — Anthropic returns 404 not_found_error.
CLAUDE_MODEL=claude-opus-4-6
GROK_MODEL=grok-4.20-multi-agent-0309
CONTEXT_MODE=hybrid

# Consensus: min models (of 4) that must agree; min confidence % on the winning side (equity vs crypto)
CONSENSUS_MIN_MODELS=3
CONSENSUS_MIN_CONFIDENCE_PERCENT=60
CONSENSUS_MIN_CONFIDENCE_CRYPTO_PERCENT=70

# Comma-separated; at least one symbol each (equities: tickers; crypto: Twelve Data pairs e.g. BTC/USD)
SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA
CRYPTO_SYMBOLS=BTC/USD,ETH/USD,SOL/USD

# Telegram — required for news/social alerts (NEWS_TELEGRAM_SOCIAL_POSTS, /run replies, etc.)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alpaca (if ALPACA_ENABLED=true, API keys are required)
ALPACA_ENABLED=false
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_PAPER=true
# Order size = MIN + strength×(MAX−MIN); strength = (supporters/4)×(mean confidence%/100)
ALPACA_ORDER_MIN_DOLLARS=100
ALPACA_ORDER_MAX_DOLLARS=1000
ALPACA_HOLD_SECONDS=3600
ALPACA_PENDING_CLOSES_FILE=pending_alpaca_closes.json

# ── News Trading Engine ────────────────────────────────────────────────────────
NEWS_TRADING_ENABLED=true
NEWS_ALPACA_ENABLED=true
NEWS_POLYGON_API_KEY=
NEWS_CRYPTO_PANIC_API_KEY=
NEWS_TRADE_DOLLARS=200
NEWS_MAX_HOLD_MINUTES=60
NEWS_STOP_LOSS_PCT=0.8
NEWS_TAKE_PROFIT_PCT=2.0
NEWS_MIN_CONFIDENCE_PCT=70
NEWS_CRYPTO_ENABLED=false
NEWS_EQUITY_ENABLED=true
# Telegram alert for every fresh Bluesky / X / Truth post (default on). If false, Telegram only
# after the fast LLM finds a ticker (_notify_new_post) or when full analysis runs.
NEWS_TELEGRAM_SOCIAL_POSTS=true

# ── News source mode ─────────────────────────────────────────────────────────
# alpaca   = Alpaca WS + Polygon + RSS (when keys / flags enabled)
# x_stream = legacy Nitter RSS path (NEWS_X_MONITOR_ENABLED) + Truth when enabled
# both     = classical + social together (same pipeline, deduped)
NEWS_SOURCE_MODE=both

# ── Bluesky (free Jetstream firehose — low latency, no API key) ─────────────
NEWS_BLUESKY_ENABLED=true
NEWS_BLUESKY_FIREHOSE_ENABLED=true
# Optional extra handles (comma-separated), e.g. user1.bsky.social,user2.bsky.social
BLUESKY_ACCOUNTS=

# ── X / Twitter (pick what your hosting and budget allow) ───────────────────
# Near real-time: official v2 filtered stream (app-only Bearer). Requires a
# developer project with access to filtered stream (not on all tiers).
NEWS_X_API_STREAM_ENABLED=false
X_BEARER_TOKEN=
# Free syndication/embed polling — often HTTP 429 from datacenter IPs; default off.
NEWS_X_SYNDICATION_ENABLED=false
# When Bluesky firehose is on, syndication is skipped unless you force it:
NEWS_X_SYNDICATION_FORCE=false
# Legacy Nitter RSS (mostly blocked):
NEWS_X_MONITOR_ENABLED=false
NITTER_INSTANCES=
HTTPS_PROXY=

# ── Truth Social (optional; polls configured accounts) ──────────────────────
NEWS_TRUTH_SOCIAL_ENABLED=true

# ── Binance (crypto news trades) ──────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true
