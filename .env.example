STOCK_DATA_API_KEY=your_twelve_data_api_key

OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
XAI_API_KEY=your_xai_api_key

# Optional overrides
OPENAI_MODEL=gpt-4.1
GEMINI_MODEL=gemini-3-flash-preview
CLAUDE_MODEL=claude-opus-4-6
GROK_MODEL=grok-4.20-multi-agent-0309
CONTEXT_MODE=hybrid

# Consensus: min models (of 4) that must agree; min confidence % on the winning side (equity vs crypto threshold)
CONSENSUS_MIN_MODELS=3
CONSENSUS_MIN_CONFIDENCE_PERCENT=60
CONSENSUS_MIN_CONFIDENCE_CRYPTO_PERCENT=70

# Optional: comma-separated equity tickers (default: top-100 style list in code)
SYMBOLS=

# Optional: comma-separated crypto pairs in Twelve Data form (default: top 20 USD pairs)
CRYPTO_SYMBOLS=

# Optional: Telegram notifications on consensus signals (crypto: alert only — trade manually; Alpaca is equities-only)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Alpaca automatic trades on consensus (paper recommended)
ALPACA_ENABLED=false
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_ORDER_DOLLARS=500
ALPACA_HOLD_SECONDS=3600
# JSON file (relative to process cwd) listing opens awaiting close across restarts; gitignored by default
ALPACA_PENDING_CLOSES_FILE=pending_alpaca_closes.json

# Shorts: same $ budget; whole-share qty from Twelve Data quote (skipped if below 1 share)