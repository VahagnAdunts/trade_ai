# Optional; can also sit in the repo root .env with the same variable names.
# Source enable flags (all default off / false in code if unset)

# Bluesky public Jetstream (no API key) — implement fast_news/sources/bluesky_jetstream.py
FAST_NEWS_BLUESKY_ENABLED=false
# Override default: wss://jetstream2.us-east.bsky.network/subscribe
# FAST_NEWS_JETSTREAM_URL=

# X API v2 filtered stream — needs Bearer; implement fast_news/sources/x_filtered_stream.py
FAST_NEWS_X_STREAM_ENABLED=false
# Reuse the same name as the main app
X_BEARER_TOKEN=

# One JSON line per post to stdout
FAST_NEWS_PRINT_JSON=true
